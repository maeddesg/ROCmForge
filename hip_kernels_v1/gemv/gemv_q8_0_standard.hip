    __half  d;
    int8_t  qs[32];
};

__global__ void rf_v1_gemv_q8_0_standard_kernel(
    const uint8_t* __restrict__ weights,
    const float*   __restrict__ input,
    float*         __restrict__ output,
    int n_rows,
