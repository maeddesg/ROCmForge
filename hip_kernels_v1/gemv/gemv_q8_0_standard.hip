    float sum = 0.0f;
    for (int block_idx = lane_id; block_idx < n_blocks_total; block_idx += WARP_SIZE) {
        const Q8_0_block* b = &w_col[block_idx];
        const float d = __half2float(b->d);
        const int row_offset = block_idx * QK8_0;

        float partial = 0.0f;
        #pragma unroll
        for (int i = 0; i < QK8_0; ++i) {
            partial += (float)b->qs[i] * s_input[row_offset + i];
        }
        sum += d * partial;
    }

    for (int offset = WARP_SIZE / 2; offset > 0; offset >>= 1) {
        sum += __shfl_down(sum, offset);
    }
    if (lane_id == 0) {
        output[col] = sum;
