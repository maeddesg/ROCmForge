    dim3 block(THREADS_PER_BLOCK, 1, 1);

    rf_v1_wmma_gemm_q4_0_fp8_kernel<<<grid, block, 0, stream>>>(
        input, weights, output, M, N, K);
    return hipGetLastError();
}
